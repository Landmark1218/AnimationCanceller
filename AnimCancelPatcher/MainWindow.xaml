<Window x:Class="AnimCancelPatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AnimCancelPatcher"
        Title="Combo Cancel Patcher" Height="580" Width="950" 
        Background="#121212" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Meiryo, sans-serif">

    <Window.Resources>
        <local:ElementToColorConverter x:Key="ElementConverter"/>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Width" Value="8"/>
        </Style>

        <DataTemplate x:Key="CharacterItemTemplate">
            <Border x:Name="CardBorder" Background="{Binding Element, Converter={StaticResource ElementConverter}}" 
                    CornerRadius="6" Padding="12" Margin="8" Width="140" Height="190" Cursor="Hand">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.3" Direction="270" ShadowDepth="4"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" CornerRadius="4" Background="#33000000" Margin="0,0,0,8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="{Binding AbsoluteIconPath}" Width="100" Height="100" Stretch="Uniform" Margin="4"/>
                    </Border>
                    <TextBlock x:Name="CharacterNameText" Grid.Row="1" Text="{Binding Name}" FontWeight="Bold" Foreground="White" 
                               TextAlignment="Center" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,6"/>
                    <Border Grid.Row="2" Background="#88000000" CornerRadius="3" HorizontalAlignment="Center" Padding="6,2">
                        <TextBlock Text="{Binding CharacterId}" Foreground="#DDDDDD" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}, Path=IsSelected}" Value="True">
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#007ACC"/>
                    <Setter TargetName="CardBorder" Property="BorderThickness" Value="3"/>
                    <Setter TargetName="CardBorder" Property="Margin" Value="5"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="CardBorder" Property="Opacity" Value="0.85"/>
                </Trigger>
                <DataTrigger Binding="{Binding Element}" Value="Yellow">
                    <Setter TargetName="CharacterNameText" Property="Foreground" Value="Black"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="CompactExecuteButton">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#0099FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#005C99"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="15">
                    <TextBlock Text="M E L E E   C A N C E L L E R" Foreground="#888888" FontSize="14" FontWeight="Bold"/>
                </Border>

                <ListBox x:Name="CharacterListBox" Grid.Row="1" 
                         ItemTemplate="{StaticResource CharacterItemTemplate}" 
                         SelectionChanged="CharacterListBox_SelectionChanged"
                         Background="Transparent" BorderThickness="0" Margin="10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Margin="10,0,0,0" Padding="20">
            <StackPanel>
                <TextBlock Text="P A T C H   S E T T I N G S" Foreground="#888888" FontSize="14" FontWeight="Bold" Margin="0,0,0,25"/>

                <TextBlock Text="AES Key" Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="AesKeyDisplayText" Text="Waiting for initialization..." Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,0,0,15" TextWrapping="Wrap"/>

                <TextBlock Text="Install Path" Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="InstallPathDisplayText" Text="Waiting for initialization..." Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,0,0,25" TextWrapping="Wrap"/>

                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Combo Stage Setup" Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="1" Foreground="#777777" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Slider x:Name="StageSlider" Grid.Column="1" Minimum="1" Maximum="5" Value="4" 
                                    TickPlacement="None" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Maximum, ElementName=StageSlider}" Foreground="#777777" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBlock Text="Target Stage :" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Border Background="#007ACC" CornerRadius="4" Padding="8,2">
                                <TextBlock Text="{Binding ElementName=StageSlider, Path=Value}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- <Button Content="Test" Visibility="Collapsed" /> -->

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <TextBlock x:Name="StatusText" Foreground="#A6E3A1" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold"/>
                    <Button x:Name="PatchButton" Content="EXTRACT &amp;&#x0a;PATCH" Style="{StaticResource CompactExecuteButton}" Click="ExecutePatch_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <TextBlock Text="@Landmark0920, TheBingChilled"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="White" Opacity="0.55"
                   FontSize="10" IsHitTestVisible="False" Grid.Column="1" Margin="0,0,4,2"/>
    </Grid>
</Window>